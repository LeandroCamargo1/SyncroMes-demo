# Synchro MES — Variáveis de Ambiente (copie para .env)

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/synchro_mes

# JWT
SECRET_KEY=synchro-mes-demo-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — origens permitidas (separar por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App
APP_TITLE=Synchro MES
APP_VERSION=2.0.0
DEBUG=true
